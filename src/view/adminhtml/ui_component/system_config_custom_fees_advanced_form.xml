<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">system_config_custom_fees_advanced_form.system_config_custom_fees_advanced_form_data_source</item>
            <item name="deps" xsi:type="string">system_config_custom_fees_advanced_form.system_config_custom_fees_advanced_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Advanced Settings</item>
        <item name="config" xsi:type="array">
            <item name="dataScope" xsi:type="string">data</item>
            <item name="namespace" xsi:type="string">system_config_custom_fees_advanced_form</item>
        </item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <dataSource name="system_config_custom_fees_advanced_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <dataProvider class="JosephLeedy\CustomFees\Ui\DataProvider\CustomFeesAdvancedConfigForm" name="system_config_custom_fees_advanced_form_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="test_fieldset">
        <settings>
            <label translate="true">Test Fieldset</label>
        </settings>
        <field name="test_field" formElement="input">
            <settings>
                <label translate="true">Test Field</label>
                <dataType>text</dataType>
            </settings>
        </field>
    </fieldset>
</form>